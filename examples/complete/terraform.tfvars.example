# Example terraform.tfvars file
# Copy this file to terraform.tfvars and fill in your values

# Your AWS account ID (12 digits)
account_id = "123456789012"

# Display name for your account in CyberArk CCE
account_display_name = "My Production AWS Account - Complete"

# AWS region for deployment
aws_region = "us-east-1"

# Enable AWS IAM Identity Center (SSO) integration
enable_sso = true

# Region where IAM Identity Center is configured
sso_region = "us-east-1"

